    {
      "category": "V2规则参数",
      "cases": [
        {
          "id": "TC-V2-025",
          "module": "V2规则",
          "sub_module": "V反顶部",
          "title": "V反顶部用high找高点且左侧累计涨幅>=5%",
          "priority": "high",
          "pre_condition": "存在V型顶部形态",
          "steps": [
            {"step_no": 1, "action": "检查V反顶部使用high而非close找高点", "expected_result": "高点为区间内最高价"},
            {"step_no": 2, "action": "检查回看窗口为20天", "expected_result": "lookback=20"},
            {"step_no": 3, "action": "检查左侧累计涨幅>=5%", "expected_result": "rise_pct>=0.05"},
            {"step_no": 4, "action": "检查从高点回落>=2%", "expected_result": "drop_pct>=0.02"}
          ]
        },
        {
          "id": "TC-V2-026",
          "module": "V2规则",
          "sub_module": "V反底部",
          "title": "V反底部用low找低点且左侧累计跌幅>=5%",
          "priority": "high",
          "pre_condition": "存在V型底部形态",
          "steps": [
            {"step_no": 1, "action": "检查V反底部使用low而非close找低点", "expected_result": "低点为区间内最低价"},
            {"step_no": 2, "action": "检查回看窗口为20天", "expected_result": "lookback=20"},
            {"step_no": 3, "action": "检查左侧累计跌幅>=5%", "expected_result": "drop_pct>=0.05"},
            {"step_no": 4, "action": "检查反弹>=2%", "expected_result": "bounce_pct>=0.02"}
          ]
        },
        {
          "id": "TC-V2-027",
          "module": "V2规则",
          "sub_module": "M顶跌破",
          "title": "M顶跌破从高点回落2%触发",
          "priority": "high",
          "pre_condition": "存在M顶形态",
          "steps": [
            {"step_no": 1, "action": "检查M顶跌破使用从高点回落2%而非颈线跌破", "expected_result": "close<top_price*0.98"},
            {"step_no": 2, "action": "检查M顶跌破为必卖规则", "expected_result": "触发后confidence=1.0"}
          ]
        },
        {
          "id": "TC-V2-028",
          "module": "V2规则",
          "sub_module": "均线趋势打破必卖",
          "title": "均线趋势打破必卖只在上升趋势触发",
          "priority": "high",
          "pre_condition": "MA处于上升状态",
          "steps": [
            {"step_no": 1, "action": "检查MA必须处于上升状态（ma[idx]>ma[idx-1]）", "expected_result": "下跌趋势中不触发"},
